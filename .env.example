# ── Required secrets (generate once, keep safe) ─────────────────────────────
POSTGRES_PASSWORD=change-me
# openssl rand -base64 32 — encrypts provider credentials; losing it orphans them
TOKENTRAIL_MASTER_KEY=
# openssl rand -base64 48
JWT_SECRET=

# ── Connections (defaults match docker-compose.dev.yml) ─────────────────────
DATABASE_URL=postgresql://tokentrail:change-me@localhost:5432/tokentrail
REDIS_URL=redis://localhost:6379

# ── Instance ─────────────────────────────────────────────────────────────────
PUBLIC_BASE_URL=http://localhost:8080
LOG_LEVEL=info
GATEWAY_FAILURE_POLICY=FAIL_OPEN   # FAIL_OPEN | FAIL_CLOSED
EVENT_RETENTION_DAYS=90

# ── Service ports (local dev) ────────────────────────────────────────────────
API_PORT=4000
GATEWAY_PORT=4100

# ── Email (mailpit in dev: docker-compose.dev.yml exposes UI on :8025) ──────
SMTP_URL=smtp://localhost:1025

# ── Instance super-admin (cross-workspace platform view) ────────────────────
# Comma-separated emails granted the super-admin "Platform" view.
SUPERADMIN_EMAILS=

# ── Enterprise ────────────────────────────────────────────────────────────────
LICENSE_KEY=

# ── Production only (deploy/docker-compose.prod.yml) — see DEPLOY.md ────────
# IMAGE_PREFIX/TAG select which published image to pull. Pin TAG to a real
# release or "main" — an unset/mistyped TAG silently falls back to "latest",
# which only moves when you cut a vX.Y.Z git tag, so you can "pull" and still
# get a stale image with none of your recent fixes.
IMAGE_PREFIX=ghcr.io/<owner>/tokentrail
TAG=main
# Path A only (bundled Caddy owns :80/:443, no existing reverse proxy on this
# host) — enables Caddy's automatic HTTPS. Leave unset for Path B (you already
# run nginx/Caddy/Traefik here) — see DEPLOY.md.
DOMAIN=
